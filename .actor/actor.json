{
  "actorSpecification": 1,
  "name": "apple-app-store-scraper",
  "title": "Apple App Store Scraper - Apps, Ratings & Prices",
  "description": "Scrape Apple App Store apps by search term or app ID. Extract names, developers, ratings, prices, genres, versions, screenshots, and descriptions. No login or API key needed.",
  "version": "1.0",
  "categories": ["BUSINESS", "DEVELOPER_TOOLS", "ECOMMERCE"],
  "dockerfile": "Dockerfile",
  "input": "../INPUT_SCHEMA.json",
  "readme": "../README.md",
  "output": "./output_schema.json",
  "storages": {
    "dataset": {
      "actorSpecification": 1,
      "views": {
        "apps": {
          "title": "Apps",
          "transformation": {
            "fields": ["appId", "appName", "developer", "primaryGenre", "price", "formattedPrice", "currency", "rating", "ratingCount", "version", "contentRating", "minimumOsVersion", "bundleId", "appStoreUrl", "artworkUrl", "currentVersionReleaseDate", "country", "scrapedAt"]
          },
          "display": {
            "component": "table",
            "properties": {
              "appId": { "label": "App ID", "format": "text" },
              "appName": { "label": "Name", "format": "text" },
              "developer": { "label": "Developer", "format": "text" },
              "primaryGenre": { "label": "Genre", "format": "text" },
              "price": { "label": "Price", "format": "number" },
              "formattedPrice": { "label": "Price (text)", "format": "text" },
              "currency": { "label": "Currency", "format": "text" },
              "rating": { "label": "Rating", "format": "number" },
              "ratingCount": { "label": "Ratings", "format": "number" },
              "version": { "label": "Version", "format": "text" },
              "contentRating": { "label": "Content Rating", "format": "text" },
              "minimumOsVersion": { "label": "Min OS", "format": "text" },
              "bundleId": { "label": "Bundle ID", "format": "text" },
              "appStoreUrl": { "label": "App Store URL", "format": "link" },
              "artworkUrl": { "label": "Icon", "format": "image" },
              "currentVersionReleaseDate": { "label": "Updated", "format": "date" },
              "country": { "label": "Country", "format": "text" },
              "scrapedAt": { "label": "Scraped At", "format": "text" }
            }
          }
        }
      }
    }
  },
  "pricingInfo": {
    "pricingModel": "PAY_PER_EVENT",
    "pricingPerEvent": {
      "actorChargeEvents": {
        "app-scraped": {
          "eventTitle": "App Scraped",
          "eventDescription": "Charged for each App Store app extracted and saved to the dataset.",
          "eventPriceUsd": 0.002,
          "isPrimaryEvent": true,
          "isOneTimeEvent": false
        },
        "apify-actor-start": {
          "eventTitle": "Actor Start",
          "eventDescription": "Charged when the Actor starts running. Number of events charged depends on Actor memory (one event per GB, minimum one event).",
          "eventPriceUsd": 0.00005,
          "isPrimaryEvent": false,
          "isOneTimeEvent": true
        }
      }
    }
  },
  "defaultRunOptions": {
    "build": "latest",
    "memoryMbytes": 512,
    "timeoutSecs": 3600
  },
  "minMemoryMbytes": 256,
  "maxMemoryMbytes": 4096
}
