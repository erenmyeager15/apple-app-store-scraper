  "description": "Apify Actor that scrapes app data from the Apple App Store via the public iTunes Search API",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "start": "node dist/main.js",
    "build": "tsc",
    "lint": "tsc --noEmit"
  },
  "keywords": ["apify", "apple", "app-store", "itunes", "apps", "scraper", "crawlee"],
